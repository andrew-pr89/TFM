# Copia este fichero a .env y rellena los valores
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# Base de datos
# Desarrollo:
DATABASE_URL=sqlite:///./carbon_agent.db
# Producción (Railway añade esta variable automáticamente al conectar PostgreSQL):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# App
APP_ENV=development
APP_DEBUG=true

# URL del frontend en producción (para CORS)
# Ejemplo: https://carbon-agent.vercel.app
FRONTEND_URL=
